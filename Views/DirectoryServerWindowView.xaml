<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Irc7m.Views"
             xmlns:vm="clr-namespace:Irc7m.ViewModels"
             x:Class="Irc7m.Views.DirectoryServerWindowView"
             x:DataType="vm:DirectoryServerViewModel"
             BackgroundColor="#1e1e1e">
    <Grid x:Name="RootGrid" ColumnDefinitions="*, Auto, Auto">
        <views:ChatWindowView x:Name="ChatView" Grid.Column="0" />
        <Grid Grid.Column="1"
              IsVisible="{Binding IsDebugMode}"
              WidthRequest="8"
              BackgroundColor="#1e1e1e">
            <Label Text="&#x22EE;"
                   TextColor="#555555"
                   FontSize="18"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnDividerPanUpdated" />
            </Grid.GestureRecognizers>
        </Grid>
        <Grid Grid.Column="2"
              IsVisible="{Binding IsDebugMode}"
              WidthRequest="{Binding DebugPanelWidth}"
              RowDefinitions="32, *, 2"
              BackgroundColor="#0d1117">
            <Grid Grid.Row="0"
                  ColumnDefinitions="*, Auto"
                  BackgroundColor="#161b22"
                  Padding="8,0">
                <Label Grid.Column="0"
                       Text="&#x26A1; Socket Debug"
                       TextColor="#58a6ff"
                       FontSize="{DynamicResource AppFontSize}"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="Clear"
                        Command="{Binding ClearDebugCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#8b949e"
                        FontSize="{DynamicResource AppFontSize}"
                        HeightRequest="28"
                        Padding="8,0" />
            </Grid>
            <Editor x:Name="DebugEditor"
                    Grid.Row="1"
                    Text="{Binding DebugText}"
                    IsReadOnly="True"
                    BackgroundColor="#0d1117"
                    TextColor="#8b949e"
                    FontFamily="Courier New"
                    FontSize="{DynamicResource AppFontSize}"
                    Margin="4,2" />
            <BoxView Grid.Row="2" Color="#30363d" HeightRequest="2" />
        </Grid>
    </Grid>
</ContentView>
