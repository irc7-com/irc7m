<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Irc7m.ViewModels"
             xmlns:conv="clr-namespace:Irc7m.Converters"
             x:Class="Irc7m.MainPage"
             x:Name="PageRoot"
             Title="Irc7m"
             BackgroundColor="#1e1e1e">


    <!-- ── Native menu bar ───────────────────────────────────────────────────── -->
    <ContentPage.MenuBarItems>

        <!-- File ──────────────────────────────────────────────────────────────── -->
        <MenuBarItem Text="File">
            <MenuFlyoutItem x:Name="ConnectMenuItem"
                            Text="Connect…"
                            Clicked="OnConnectDisconnectClicked" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Preferences…" Clicked="OnPreferencesClicked" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Servers…"     Clicked="OnServersClicked" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Script Editor…" Clicked="OnScriptEditorClicked" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Quit"  Clicked="OnQuitClicked" />
            <MenuFlyoutItem Text="Exit"  Clicked="OnQuitClicked" />
        </MenuBarItem>

        <!-- Edit ──────────────────────────────────────────────────────────────── -->
        <MenuBarItem Text="Edit">
            <MenuFlyoutItem Text="Cut"        Clicked="OnCutClicked" />
            <MenuFlyoutItem Text="Copy"       Clicked="OnCopyClicked" />
            <MenuFlyoutItem Text="Paste"      Clicked="OnPasteClicked" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Select All" Clicked="OnSelectAllClicked" />
        </MenuBarItem>

        <!-- View ──────────────────────────────────────────────────────────────── -->
        <MenuBarItem Text="View">
            <MenuFlyoutItem Text="Horizontal Tabs" Clicked="OnHorizontalTabsClicked" />
            <MenuFlyoutItem Text="Vertical Tabs"   Clicked="OnVerticalTabsClicked" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem x:Name="CtcpTimeMenuItem"
                            Text="CTCP Time Reply  ✓"
                            Clicked="OnToggleCtcpTimeClicked" />
        </MenuBarItem>

        <!-- Rooms ─────────────────────────────────────────────────────────────── -->
        <MenuBarItem Text="Rooms">
            <MenuFlyoutItem Text="Join…"         Clicked="OnJoinClicked" />
            <MenuFlyoutItem Text="Part"          Clicked="OnPartClicked" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Recent Rooms…" Clicked="OnRecentRoomsClicked" />
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Channel List"  Clicked="OnChannelListClicked" />
        </MenuBarItem>

        <!-- Help ──────────────────────────────────────────────────────────────── -->
        <MenuBarItem Text="Help">
            <MenuFlyoutItem Text="About Irc7m" Clicked="OnAboutClicked" />
        </MenuBarItem>

    </ContentPage.MenuBarItems>

    <!-- ── Converters ─────────────────────────────────────────────────────── -->
    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:BoolToColorConverter x:Key="TabBgConv"
                                       TrueColor="#3c3c3c"
                                       FalseColor="#252526" />
            <conv:BoolToColorConverter x:Key="TabFgConv"
                                       TrueColor="#ffffff"
                                       FalseColor="#888888" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="30, 36, *">

        <!-- ── In-window menu bar ──────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              BackgroundColor="#252526"
              x:Name="MenuBarGrid">

            <HorizontalStackLayout VerticalOptions="Center" Padding="4,0" Spacing="0"
                                   x:Name="MenuLabelsLayout">

                <Label x:Name="FileMenuLabel"    Text="  File  "
                       TextColor="#cccccc" FontSize="13" VerticalOptions="Center"
                       BackgroundColor="Transparent">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFileMenuTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label x:Name="EditMenuLabel"    Text="  Edit  "
                       TextColor="#cccccc" FontSize="13" VerticalOptions="Center"
                       BackgroundColor="Transparent">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnEditMenuTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label x:Name="ViewMenuLabel"    Text="  View  "
                       TextColor="#cccccc" FontSize="13" VerticalOptions="Center"
                       BackgroundColor="Transparent">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnViewMenuTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label x:Name="RoomsMenuLabel"   Text="  Rooms  "
                       TextColor="#cccccc" FontSize="13" VerticalOptions="Center"
                       BackgroundColor="Transparent">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRoomsMenuTapped" />
                    </Label.GestureRecognizers>
                </Label>

                <Label x:Name="HelpMenuLabel"    Text="  Help  "
                       TextColor="#cccccc" FontSize="13" VerticalOptions="Center"
                       BackgroundColor="Transparent">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHelpMenuTapped" />
                    </Label.GestureRecognizers>
                </Label>

            </HorizontalStackLayout>

        </Grid>

        <!-- ── Tab bar ────────────────────────────────────────────────────── -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    BackgroundColor="#252526"
                    HeightRequest="36"
                    VerticalScrollBarVisibility="Never">

            <HorizontalStackLayout Spacing="1"
                                   Padding="4,4,4,0"
                                   BindableLayout.ItemsSource="{Binding Tabs}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChatWindowViewModel">
                        <Border StrokeShape="RoundRectangle 4,4,0,0"
                                BackgroundColor="{Binding IsSelected, Converter={StaticResource TabBgConv}}"
                                Padding="12,5,8,5"
                                StrokeThickness="0">

                            <!-- Right-click on the tab to toggle/clear the debug panel -->
                            <FlyoutBase.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Toggle Debug Panel"
                                                    Command="{Binding ToggleDebugCommand}" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Clear Debug Log"
                                                    Command="{Binding ClearDebugCommand}" />
                                </MenuFlyout>
                            </FlyoutBase.ContextFlyout>

                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">

                                <!-- Connection state indicator (● green/red, ⚡ orange) -->
                                <Label Text="{Binding ConnectionIndicator}"
                                       TextColor="{Binding ConnectionIndicatorColor}"
                                       FontSize="10"
                                       VerticalOptions="Center" />

                                <Label Text="{Binding Title}"
                                       TextColor="{Binding IsSelected, Converter={StaticResource TabFgConv}}"
                                       FontSize="{DynamicResource AppFontSize}"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.SelectTabCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>

                                <Label Text="✕"
                                       TextColor="#666666"
                                       FontSize="{DynamicResource AppFontSize}"
                                       IsVisible="{Binding IsCloseable}"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.CloseTabCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>

                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- ── Content area (populated from code-behind on tab change) ──────── -->
        <ContentView x:Name="ContentArea"
                     Grid.Row="2"
                     BackgroundColor="#1e1e1e" />

        <!-- ── Dropdown overlay (spans all rows; shown/hidden from code-behind) ── -->
        <Border x:Name="DropdownPanel"
                Grid.Row="0" Grid.RowSpan="3"
                IsVisible="False"
                StrokeShape="RoundRectangle 0,0,4,4"
                Stroke="#555555"
                BackgroundColor="#2d2d2d"
                VerticalOptions="Start"
                HorizontalOptions="Start"
                ZIndex="100"
                MinimumWidthRequest="200"
                Padding="0,4"
                Shadow="{Shadow Brush='#88000000', Offset='2,2', Radius=6}">
            <VerticalStackLayout x:Name="DropdownItems" Spacing="0" />
        </Border>

    </Grid>
</ContentPage>
